@model List<FeaneMVC.Models.MailMessage>

@{
    ViewData["Title"] = "Mail Dashboard";
    Layout = null;
    // Group emails by filter
    var emailsByFilter = Model.GroupBy(m => m.Filter).ToDictionary(g => g.Key, g => g.ToList());

    // Get all unique filters
    var filters = emailsByFilter.Keys.ToList();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --background: #f8fafc;
            --sidebar-bg: #f1f5f9;
            --card-bg: #ffffff;
            --text: #1e293b;
            --text-secondary: #64748b;
            --border: #e2e8f0;
            --shadow: rgba(0, 0, 0, 0.1);
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;
            --radius: 0.5rem;
            --transition: all 0.3s ease;
            --header-height: 64px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        body {
            background: var(--background);
            color: var(--text);
            min-height: 100vh;
            overflow: hidden;
        }

        .app-container {
            display: flex;
            height: 100vh;
        }

        /* Header */
        .header {
            height: var(--header-height);
            display: flex;
            align-items: center;
            padding: 0 1.5rem;
            background: var(--card-bg);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 10;
            justify-content: space-between;
        }

        .header-title {
            font-size: 1.25rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .header-actions {
            display: flex;
            gap: 0.75rem;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border);
            height: 100vh;
            overflow-y: auto;
            transition: var(--transition);
            display: flex;
            flex-direction: column;
        }

        .sidebar-header {
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .sidebar-title {
            font-size: 1.25rem;
            font-weight: 600;
        }

        .filter-list {
            list-style: none;
            padding: 0.5rem 0;
            flex: 1;
        }

        .filter-item {
            padding: 0.75rem 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            transition: var(--transition);
            border-left: 3px solid transparent;
        }

        .filter-item:hover {
            background: rgba(99, 102, 241, 0.1);
        }

        .filter-item.active {
            background: rgba(99, 102, 241, 0.15);
            border-left: 3px solid var(--primary);
        }

        .filter-icon {
            color: var(--text-secondary);
        }

        .filter-name {
            flex: 1;
        }

        .filter-count {
            background: var(--primary);
            color: white;
            border-radius: 9999px;
            padding: 0.125rem 0.5rem;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .sidebar-footer {
            padding: 1rem 1.5rem;
            border-top: 1px solid var(--border);
        }

        /* Content */
        .content {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        .email-list {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
        }

        .email-item {
            padding: 1.25rem;
            border-radius: var(--radius);
            background: var(--card-bg);
            margin-bottom: 1rem;
            cursor: pointer;
            border: 1px solid var(--border);
            transition: var(--transition);
            animation: fadeIn 0.3s ease-out;
            display: none; /* Hide by default */
        }

        .email-item:hover {
            box-shadow: 0 4px 12px var(--shadow);
            transform: translateY(-2px);
        }

        .email-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.75rem;
        }

        .email-sender {
            font-weight: 500;
            color: var(--text);
        }

        .email-date {
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        .email-subject {
            font-weight: 600;
            margin-bottom: 0.75rem;
            color: var(--text);
        }

        .email-preview {
            color: var(--text-secondary);
            font-size: 0.875rem;
            line-height: 1.5;
            overflow: hidden;
            text-overflow: ellipsis;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
        }

        .email-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        .email-filter-tag {
            background: rgba(99, 102, 241, 0.1);
            color: var(--primary);
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .email-actions {
            display: flex;
            gap: 0.5rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: var(--radius);
            font-weight: 500;
            font-size: 0.875rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: var(--transition);
            border: none;
        }

        .btn-sm {
            padding: 0.375rem 0.75rem;
            font-size: 0.75rem;
        }

        .btn-icon {
            padding: 0.5rem;
            border-radius: 9999px;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: white;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #4f46e5, #4338ca);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text);
        }

        .btn-outline:hover {
            background: #f1f5f9;
            border-color: #cbd5e1;
        }

        .btn-ghost {
            background: transparent;
            color: var(--text-secondary);
        }

        .btn-ghost:hover {
            background: rgba(0, 0, 0, 0.05);
            color: var(--text);
        }

        .btn-icon svg {
            width: 1.25rem;
            height: 1.25rem;
        }

        .empty-state {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-secondary);
            text-align: center;
            padding: 2rem;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 1.5rem;
            color: var(--border);
        }

        .empty-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 0.75rem;
        }

        .empty-description {
            max-width: 400px;
            margin-bottom: 1.5rem;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .badge-success {
            background: rgba(16, 185, 129, 0.1);
            color: var(--success);
        }

        .badge-error {
            background: rgba(239, 68, 68, 0.1);
            color: var(--error);
        }

        .badge-warning {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }

        .badge-info {
            background: rgba(59, 130, 246, 0.1);
            color: var(--info);
        }

        .toast {
            position: fixed;
            bottom: 1.5rem;
            right: 1.5rem;
            padding: 1rem 1.5rem;
            background: white;
            color: var(--text);
            border-radius: var(--radius);
            box-shadow: 0 10px 30px var(--shadow);
            transform: translateY(100px);
            opacity: 0;
            transition: var(--transition);
            z-index: 1000;
            max-width: 350px;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }

        .toast.success {
            border-left: 4px solid var(--success);
        }

        .toast.error {
            border-left: 4px solid var(--error);
        }

        .toast.warning {
            border-left: 4px solid var(--warning);
        }

        .toast.info {
            border-left: 4px solid var(--info);
        }

        .toast-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 1.5rem;
            height: 1.5rem;
        }

        .toast-content {
            flex: 1;
        }

        .toast-title {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .toast-message {
            font-size: 0.875rem;
            color: var(--text-secondary);
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
        }

        .loading-overlay.show {
            opacity: 1;
            visibility: visible;
        }

        .loading-spinner {
            width: 40px;
            height: 40px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s linear infinite;
        }

        .loading-text {
            color: white;
            margin-top: 1rem;
            font-weight: 500;
        }

        .modal {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: var(--transition);
        }

        .modal.show {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background: var(--card-bg);
            border-radius: var(--radius);
            width: 90%;
            max-width: 600px;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 10px 30px var(--shadow);
            transform: translateY(-20px);
            transition: var(--transition);
        }

        .modal.show .modal-content {
            transform: translateY(0);
        }

        .modal-header {
            padding: 1.25rem;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-title {
            font-size: 1.25rem;
            font-weight: 600;
        }

        .modal-close {
            background: transparent;
            border: none;
            cursor: pointer;
            color: var(--text-secondary);
            width: 2rem;
            height: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 9999px;
            transition: var(--transition);
        }

        .modal-close:hover {
            background: rgba(0, 0, 0, 0.05);
            color: var(--text);
        }

        .modal-body {
            padding: 1.5rem;
        }

        .modal-footer {
            padding: 1.25rem;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 0.75rem;
        }

        /* Mobile Responsive */
        @@media (max-width: 768px) {
        .app-container {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            height: auto;
            max-height: 50vh;
        }

        .content {
            height: auto;
        }
        }

        /* Animations */
        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* Dark Mode */
        @@media (prefers-color-scheme: dark) {
        :root {
            --background: #0f172a;
            --sidebar-bg: #1e293b;
            --card-bg: #1e293b;
            --text: #f1f5f9;
            --text-secondary: #94a3b8;
            --border: #334155;
            --shadow: rgba(0, 0, 0, 0.3);
        }

        .btn-outline:hover {
            background: #1e293b;
            border-color: #475569;
        }

        .btn-ghost:hover {
            background: rgba(255, 255, 255, 0.05);
        }

        .toast {
            background: #1e293b;
        }

        .modal-content {
            background: #1e293b;
        }

        .modal-close:hover {
            background: rgba(255, 255, 255, 0.05);
        }
        }
    </style>
</head>
<body>
<div class="app-container">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <h2 class="sidebar-title">Filters</h2>
            <button class="btn btn-icon btn-ghost" id="refresh-filters-btn" title="Refresh filters">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
                </svg>
            </button>
        </div>
        <ul class="filter-list" id="filter-list">
            <li class="filter-item active" data-filter="all">
                    <span class="filter-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="3" rx="2" />
                            <path d="M7 7h10M7 12h10M7 17h10" />
                        </svg>
                    </span>
                <span class="filter-name">All Emails</span>
                <span class="filter-count">@Model.Count</span>
            </li>
            @foreach (var filter in filters)
            {
                var count = emailsByFilter[filter].Count;
                <li class="filter-item" data-filter="@filter">
                        <span class="filter-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                            </svg>
                        </span>
                    <span class="filter-name">@filter</span>
                    <span class="filter-count">@count</span>
                </li>
            }
        </ul>
        <div class="sidebar-footer">
            <button class="btn btn-primary" style="width: 100%;" id="add-filter-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 5v14M5 12h14"/>
                </svg>
                Add Filter
            </button>
        </div>
    </aside>

    <!-- Content -->
    <main class="content">
        <header class="header">
            <h1 class="header-title" id="current-filter-title">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="18" x="3" y="3" rx="2" />
                    <path d="M7 7h10M7 12h10M7 17h10" />
                </svg>
                All Emails
            </h1>
            <div class="header-actions">
                <button class="btn btn-outline" id="sync-emails-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
                    </svg>
                    Sync Emails
                </button>
            </div>
        </header>
        <div class="email-list" id="email-list">
            <div class="empty-state" id="empty-state" style="display: none;">
                <div class="empty-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                        <rect width="20" height="16" x="2" y="4" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                </div>
                <h3 class="empty-title">No emails found</h3>
                <p class="empty-description">There are no emails in this filter yet. Sync your emails to fetch new messages.</p>
                <button class="btn btn-primary" id="empty-sync-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
                    </svg>
                    Sync Emails
                </button>
            </div>

            @foreach (var email in Model)
            {
                <div class="email-item" data-filter="@email.Filter" data-id="@email.Id">
                    <div class="email-header">
                        <span class="email-sender">@email.Email</span>
                        <span class="email-date">@email.Date.ToString("MMM d, yyyy")</span>
                    </div>
                    <h3 class="email-subject">@email.Subject</h3>
                    <div class="email-preview">@(string.IsNullOrEmpty(email.Body) ? "No content" : email.Body.Length > 300 ? email.Body.Substring(0, 300) + "..." : email.Body)</div>
                    <div class="email-footer">
                        <span class="email-filter-tag">@email.Filter</span>
                        <div class="email-actions">
                            <button class="btn btn-sm btn-outline view-email-btn" data-id="@email.Id">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/>
                                    <circle cx="12" cy="12" r="3"/>
                                </svg>
                                View
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>
</div>

<!-- Email View Modal -->
<div class="modal" id="email-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title" id="email-modal-subject">Email Subject</h2>
            <button class="modal-close" id="close-modal">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18M6 6l12 12"/>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="email-header" style="margin-bottom: 1.5rem;">
                <span class="email-sender" id="email-modal-sender">sender@example.com</span>
                <span class="email-date" id="email-modal-date">Jan 1, 2023</span>
            </div>
            <div id="email-modal-body" style="line-height: 1.6;">
                Email content will appear here.
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-outline" id="close-modal-btn">Close</button>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loading-overlay">
    <div>
        <div class="loading-spinner"></div>
        <div class="loading-text" id="loading-text">Syncing emails...</div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="toast">
    <div class="toast-icon" id="toast-icon">
        <!-- Icon will be inserted by JS -->
    </div>
    <div class="toast-content">
        <div class="toast-title" id="toast-title">Notification</div>
        <div class="toast-message" id="toast-message"></div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Elements
        const filterItems = document.querySelectorAll('.filter-item');
        const emailItems = document.querySelectorAll('.email-item');
        const currentFilterTitle = document.getElementById('current-filter-title');
        const emptyState = document.getElementById('empty-state');
        const syncEmailsBtn = document.getElementById('sync-emails-btn');
        const emptySyncBtn = document.getElementById('empty-sync-btn');
        const refreshFiltersBtn = document.getElementById('refresh-filters-btn');
        const addFilterBtn = document.getElementById('add-filter-btn');
        const loadingOverlay = document.getElementById('loading-overlay');
        const loadingText = document.getElementById('loading-text');
        const toast = document.getElementById('toast');
        const toastIcon = document.getElementById('toast-icon');
        const toastTitle = document.getElementById('toast-title');
        const toastMessage = document.getElementById('toast-message');
        const emailModal = document.getElementById('email-modal');
        const closeModal = document.getElementById('close-modal');
        const closeModalBtn = document.getElementById('close-modal-btn');
        const emailModalSubject = document.getElementById('email-modal-subject');
        const emailModalSender = document.getElementById('email-modal-sender');
        const emailModalDate = document.getElementById('email-modal-date');
        const emailModalBody = document.getElementById('email-modal-body');
        const viewEmailBtns = document.querySelectorAll('.view-email-btn');

        // Show toast notification
        function showToast(title, message, type = 'success') {
            toastTitle.textContent = title;
            toastMessage.textContent = message;

            // Set icon based on type
            if (type === 'success') {
                toastIcon.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                    `;
            } else if (type === 'error') {
                toastIcon.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                    `;
            } else if (type === 'warning') {
                toastIcon.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                            <line x1="12" y1="9" x2="12" y2="13"></line>
                            <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                    `;
            } else if (type === 'info') {
                toastIcon.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="16" x2="12" y2="12"></line>
                            <line x1="12" y1="8" x2="12.01" y2="8"></line>
                        </svg>
                    `;
            }

            toast.className = `toast ${type} show`;

            setTimeout(() => {
                toast.className = 'toast';
            }, 5000);
        }

        // Show loading overlay
        function showLoading(message = 'Loading...') {
            loadingText.textContent = message;
            loadingOverlay.classList.add('show');
        }

        // Hide loading overlay
        function hideLoading() {
            loadingOverlay.classList.remove('show');
        }

        // Filter emails
        function filterEmails(filterName) {
            let hasEmails = false;

            emailItems.forEach(email => {
                const emailFilter = email.getAttribute('data-filter');

                if (filterName === 'all' || emailFilter === filterName) {
                    email.style.display = 'block';
                    // Add staggered animation
                    const delay = Array.from(emailItems).indexOf(email) * 0.05;
                    email.style.animationDelay = `${delay}s`;
                    hasEmails = true;
                } else {
                    email.style.display = 'none';
                }
            });

            // Show/hide empty state
            emptyState.style.display = hasEmails ? 'none' : 'flex';

            // Update header title
            if (filterName === 'all') {
                currentFilterTitle.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect width="18" height="18" x="3" y="3" rx="2" />
                            <path d="M7 7h10M7 12h10M7 17h10" />
                        </svg>
                        All Emails
                    `;
            } else {
                currentFilterTitle.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                        </svg>
                        ${filterName}
                    `;
            }
        }

        // Sync emails from server
        async function syncEmails() {
            showLoading('Syncing emails...');

            try {
                const response = await fetch('/api/filters/read-emails');

                if (!response.ok) {
                    throw new Error('Failed to sync emails');
                }

                const result = await response.text();

                // Refresh the page to show new emails
                showToast('Success', 'Emails synced successfully', 'success');

                // Reload emails after a short delay
                setTimeout(() => {
                    location.reload();
                }, 1500);

            } catch (error) {
                console.error('Error:', error);
                showToast('Error', 'Failed to sync emails. Please try again.', 'error');
                hideLoading();
            }
        }

        // View email details
        function viewEmail(emailId) {
            const email = document.querySelector(`.email-item[data-id="${emailId}"]`);

            if (email) {
                const subject = email.querySelector('.email-subject').textContent;
                const sender = email.querySelector('.email-sender').textContent;
                const date = email.querySelector('.email-date').textContent;
                const body = email.querySelector('.email-preview').textContent;

                emailModalSubject.textContent = subject;
                emailModalSender.textContent = sender;
                emailModalDate.textContent = date;
                emailModalBody.textContent = body;

                emailModal.classList.add('show');
            }
        }

        // Add click event to filter items
        filterItems.forEach(item => {
            item.addEventListener('click', function() {
                const filterName = this.getAttribute('data-filter');

                // Update active filter in sidebar
                filterItems.forEach(f => f.classList.remove('active'));
                this.classList.add('active');

                // Filter emails
                filterEmails(filterName);
            });
        });

        // Add click event to sync emails button
        syncEmailsBtn.addEventListener('click', syncEmails);
        emptySyncBtn.addEventListener('click', syncEmails);

        // Add click event to refresh filters button
        refreshFiltersBtn.addEventListener('click', function() {
            showLoading('Refreshing filters...');

            // Simulate refresh (in a real app, you'd fetch from server)
            setTimeout(() => {
                hideLoading();
                showToast('Success', 'Filters refreshed', 'success');
            }, 1000);
        });

        // Add click event to add filter button
        addFilterBtn.addEventListener('click', function() {
            // Redirect to add filter page
            window.location.href = '/add-filter';
        });

        // Add click event to view email buttons
        viewEmailBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const emailId = this.getAttribute('data-id');
                viewEmail(emailId);
            });
        });

        // Add click event to email items
        emailItems.forEach(item => {
            item.addEventListener('click', function() {
                const emailId = this.getAttribute('data-id');
                viewEmail(emailId);
            });
        });

        // Close modal
        closeModal.addEventListener('click', function() {
            emailModal.classList.remove('show');
        });

        closeModalBtn.addEventListener('click', function() {
            emailModal.classList.remove('show');
        });

        // Close modal when clicking outside
        emailModal.addEventListener('click', function(e) {
            if (e.target === emailModal) {
                emailModal.classList.remove('show');
            }
        });

        // Add animation to filter items
        filterItems.forEach((item, index) => {
            item.style.animation = `slideIn 0.3s ease-out forwards`;
            item.style.animationDelay = `${index * 0.05}s`;
            item.style.opacity = '0';
        });

        // Show all emails by default
        filterEmails('all');
    });
</script>
</body>
</html>