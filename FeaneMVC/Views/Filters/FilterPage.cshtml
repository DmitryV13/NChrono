@model List<FeaneMVC.Controllers.NotificationFolder>
@{
    ViewData["Title"] = "Notification Folders";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            --primary: #6366f1;
            --primary-hover: #4f46e5;
            --background: #f8fafc;
            --card-bg: #ffffff;
            --text: #1e293b;
            --text-secondary: #64748b;
            --border: #e2e8f0;
            --shadow: rgba(0, 0, 0, 0.1);
            --success: #10b981;
            --error: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;
            --radius: 0.5rem;
            --transition: all 0.3s ease;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        }

        body {
            background-color: var(--background);
            color: var(--text);
            line-height: 1.5;
        }

        .container {
            width: 100%;
            max-width: 48rem;
            margin-left: auto;
            margin-right: auto;
            padding: 2rem 1rem;
        }

        .page-title {
            font-size: 1.75rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            color: var(--text);
        }

        .folders-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .folder-card {
            background-color: var(--card-bg);
            border-radius: var(--radius);
            border: 1px solid var(--border);
            overflow: hidden;
            transition: box-shadow 0.3s ease, transform 0.2s ease;
        }

        .folder-card:hover {
            box-shadow: 0 4px 12px var(--shadow);
        }

        .folder-header {
            padding: 1.25rem 1.5rem;
            cursor: pointer;
            user-select: none;
        }

        .folder-header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .folder-title-section {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .folder-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
        }

        .folder-title {
            font-size: 1.125rem;
            font-weight: 600;
            color: var(--text);
        }

        .folder-meta {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .folder-count {
            background-color: rgba(99, 102, 241, 0.1);
            color: var(--primary);
            border-radius: 9999px;
            padding: 0.25rem 0.75rem;
            font-size: 0.75rem;
            font-weight: 500;
        }

        .chevron-icon {
            transition: transform 0.3s ease;
        }

        .chevron-icon.rotated svg {
            transform: rotate(180deg);
        }

        .folder-summary {
            padding: 0 1.5rem 1.25rem;
            color: var(--text-secondary);
            font-size: 0.875rem;
        }

        .folder-content {
            height: 0;
            overflow: hidden;
            transition: height 0.4s ease-in-out;
        }

        .folder-divider {
            height: 1px;
            background-color: var(--border);
            border: none;
            margin: 0 1.5rem;
        }

        .notifications-list {
            padding: 1.25rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .empty-message {
            text-align: center;
            color: var(--text-secondary);
            padding: 2rem 0;
            font-size: 0.875rem;
        }

        .notification-item {
            padding: 1rem;
            background-color: rgba(99, 102, 241, 0.05);
            border-radius: var(--radius);
            border: 1px solid rgba(99, 102, 241, 0.1);
            transition: var(--transition);
        }

        .notification-item:hover {
            background-color: rgba(99, 102, 241, 0.1);
        }

        .notification-content {
            display: flex;
            gap: 0.75rem;
        }

        .notification-body {
            flex: 1;
        }

        .notification-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 0.25rem;
        }

        .notification-title {
            font-weight: 600;
            color: var(--text);
            font-size: 0.9375rem;
        }

        .notification-time {
            color: var(--text-secondary);
            font-size: 0.75rem;
        }

        .notification-message {
            color: var(--text-secondary);
            font-size: 0.875rem;
            margin-bottom: 0.5rem;
        }

        .notification-source {
            color: var(--text-secondary);
            font-size: 0.75rem;
        }

        .back-button {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.5rem 1rem;
            background-color: transparent;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            color: var(--text-secondary);
            font-size: 0.875rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            margin-bottom: 1.5rem;
        }

        .back-button:hover {
            background-color: rgba(0, 0, 0, 0.05);
            color: var(--text);
        }

        /* Dark Mode */
        @@media (prefers-color-scheme: dark) {
        :root {
            --background: #0f172a;
            --card-bg: #1e293b;
            --text: #f1f5f9;
            --text-secondary: #94a3b8;
            --border: #334155;
            --shadow: rgba(0, 0, 0, 0.3);
        }

        .notification-item {
            background-color: rgba(99, 102, 241, 0.1);
            border-color: rgba(99, 102, 241, 0.2);
        }

        .notification-item:hover {
            background-color: rgba(99, 102, 241, 0.15);
        }

        .back-button:hover {
            background-color: rgba(255, 255, 255, 0.05);
        }
        }
    </style>
</head>
<body>
<div class="container">
    <button class="back-button" onclick="window.history.back()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back
    </button>

    <h1 class="page-title">Notification Folders</h1>

    <div class="folders-grid">
        @foreach (var folder in Model)
        {
            <div class="folder-card" data-folder-id="@folder.GetHashCode()">
                <div class="folder-header" onclick="toggleFolder(@folder.GetHashCode())">
                    <div class="folder-header-content">
                        <div class="folder-title-section">
                            <div class="folder-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                                </svg>
                            </div>
                            <h3 class="folder-title">@folder.Name</h3>
                        </div>
                        <div class="folder-meta">
                            <span class="folder-count">@folder.Notifications.Count</span>
                            <div class="chevron-icon" id="chevron-@folder.GetHashCode()">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="folder-summary" id="summary-@folder.GetHashCode()">
                    @if (folder.Notifications.Count == 0)
                    {
                        <span>No notifications</span>
                    }
                    else
                    {
                        <span>@folder.Notifications.Count notification@(folder.Notifications.Count == 1 ? "" : "s")</span>
                    }
                </div>

                <div class="folder-content" id="content-@folder.GetHashCode()">
                    <hr class="folder-divider" />
                    <div class="notifications-list">
                        @if (folder.Notifications.Count == 0)
                        {
                            <div class="empty-message">No notifications in this folder</div>
                        }
                        else
                        {
                            foreach (var notification in folder.Notifications)
                            {
                                <div class="notification-item">
                                    <div class="notification-content">
                                        <div class="notification-body">
                                            <div class="notification-header">
                                                <h4 class="notification-title">
                                                    @(notification.Summary ?? "No summary")
                                                </h4>
                                                <span class="notification-time">@notification.TimeString</span>
                                            </div>
                                            <p class="notification-message">
                                                @(notification.Prefix != null ? $"{notification.Prefix}: " : "")
                                                @(notification.Body ?? "No body")
                                            </p>
                                            <p class="notification-source">From: @(notification.AppName ?? "Unknown app")</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize all folders
        document.querySelectorAll('.folder-card').forEach(function(folder) {
            const folderId = folder.getAttribute('data-folder-id');
            const content = document.getElementById('content-' + folderId);

            // Make sure content is initially collapsed
            content.style.height = '0';
        });
    });

    function toggleFolder(folderId) {
        const content = document.getElementById('content-' + folderId);
        const summary = document.getElementById('summary-' + folderId);
        const chevronIcon = document.getElementById('chevron-' + folderId);

        if (content.style.height === '0px' || content.style.height === '') {
            // Expand
            content.style.height = content.scrollHeight + 'px';
            summary.style.display = 'none';
            chevronIcon.classList.add('rotated');

            // Add event listener for transition end to set height to auto
            // This allows the content to expand if more items are added dynamically
            const transitionEndHandler = function() {
                content.style.height = 'auto';
                content.removeEventListener('transitionend', transitionEndHandler);
            };
            content.addEventListener('transitionend', transitionEndHandler);
        } else {
            // First set a specific height (instead of auto) to enable the transition
            content.style.height = content.scrollHeight + 'px';

            // Force a reflow to ensure the browser recognizes the change
            content.offsetHeight;

            // Then set height to 0 to trigger the transition
            content.style.height = '0';
            summary.style.display = 'block';
            chevronIcon.classList.remove('rotated');
        }
    }
</script>
</body>
</html>