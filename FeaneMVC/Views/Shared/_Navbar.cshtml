<div class="hero_area">
    <div class="bg-box">
        <img src="~/images/hero-bg.jpg" alt="NChrono Background">
    </div>
    <!-- header section starts -->
    <header class="header_section">
        <div class="container">
            <nav class="navbar navbar-expand-lg custom_nav-container">
                <a class="navbar-brand" href="/home/index">
                    <span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="navbar-logo-icon">
                            <circle cx="12" cy="12" r="10"/>
                            <polyline points="12 6 12 12 16 14"/>
                        </svg>
                        NChrono
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Reservation" asp-action="Book">Book Table</a>
                        </li>
                    </ul>

                    <div class="user_option">
                        <a href="/account/profile" class="user_link">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                                <circle cx="12" cy="7" r="4"></circle>
                            </svg>
                        </a>
                        <a class="cart_link" href="/cart/cart" title="View Cart">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="9" cy="21" r="1"></circle>
                                <circle cx="20" cy="21" r="1"></circle>
                                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                            </svg>
                        </a>
                        <a href="/home/index" class="order_online">
                            Order Online
                        </a>

                        @* Conditional button for admins and moderators *@
                        @if (Context.Session.GetString("UserRole") == "Admin" || Context.Session.GetString("UserRole") == "Moderator")
                        {
                            <a href="@Url.Action("Index", "Dish")" class="admin_button">
                                Manage Dishes
                            </a>
                            <a href="@Url.Action("Index", "User")" class="admin_button">
                                Manage Users
                            </a>
                        }
                    </div>
                </div>
            </nav>
        </div>
    </header>
    <!-- end header section -->
</div>

<style>
    /* Modern Hero Area Styles */
    .hero_area {
        position: relative;
        min-height: 500px;
        z-index: 1;
        background-size: cover;
    }

    .bg-box {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
    }

    .bg-box img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .bg-box::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
    }

    .header_section {
        padding: 20px 0;
    }

    .navbar-brand {
        font-size: 1.75rem;
        font-weight: 700;
        color: #fff;
        display: flex;
        align-items: center;
    }

    .navbar-brand span {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .navbar-logo-icon {
        margin-right: 0.25rem;
    }

    .navbar-toggler {
        border: none;
        background: transparent;
        color: white;
        padding: 0.5rem;
        border-radius: 0.25rem;
        transition: background-color 0.3s ease;
    }

    .navbar-toggler:focus {
        outline: none;
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.2);
    }

    .navbar-toggler:hover {
        background-color: rgba(255, 255, 255, 0.1);
    }

    .navbar-nav .nav-link {
        font-size: 1rem;
        color: #fff;
        margin-right: 1.5rem;
        padding: 0.5rem 0;
        transition: all 0.3s ease;
        position: relative;
        font-weight: 500;
    }

    .navbar-nav .nav-link:hover {
        color: #6366f1;
    }

    .navbar-nav .nav-link.active {
        color: #6366f1;
    }

    .navbar-nav .nav-link.active::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 2px;
        background-color: #6366f1;
        border-radius: 1px;
    }

    .user_option {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .user_option a {
        color: #fff;
        transition: all 0.3s ease;
    }

    .user_option a:hover {
        color: #6366f1;
    }

    .user_link, .cart_link {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        transition: all 0.3s ease;
    }

    .user_link:hover, .cart_link:hover {
        background-color: rgba(255, 255, 255, 0.1);
    }

    .order_online {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        padding: 0.5rem 1.25rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        height: 40px;
        text-transform: uppercase;
    }

    .order_online:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
    }

    .admin_button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #ef4444;
        color: white;
        padding: 0.5rem 1.25rem;
        border-radius: 9999px;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        border: none;
        height: 40px;
        margin-left: 0.5rem;
        text-transform: uppercase;
    }

    .admin_button:hover {
        background: #dc2626;
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
    }

    /* Responsive Styles */
    @@media (max-width: 992px) {
    .navbar-collapse {
        background-color: rgba(30, 41, 59, 0.95);
        backdrop-filter: blur(10px);
        margin: 0 -1rem;
        padding: 1rem;
        border-radius: 0.5rem;
        margin-top: 1rem;
    }

    .navbar-nav {
        margin-bottom: 1rem;
    }

    .user_option {
        flex-wrap: wrap;
        justify-content: center;
    }

    .admin_button {
        margin-top: 0.5rem;
    }
    }

    /* Dark Mode Support */
    @@media (prefers-color-scheme: dark) {
    .navbar-collapse {
        background-color: rgba(15, 23, 42, 0.95);
    }
    }
</style>