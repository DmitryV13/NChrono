@model WebApplication1.Models.CartAndDishes

<section class="food_section layout_padding-bottom">
    <div class="container">
        <div class="heading_container heading_center">
            <h2>Our Menu</h2>
        </div>

        <!-- Filters -->
        <ul class="filters_menu">
            <li class="active" data-filter="*">All</li>
            <li data-filter=".burger">Burger</li>
            <li data-filter=".pizza">Pizza</li>
            <li data-filter=".pasta">Pasta</li>
            <li data-filter=".fries">Fries</li>
        </ul>

        <!-- Content -->
        <div class="filters-content">

        </div>
    </div>
</section>

<!-- Add your CSS for filtering here -->
<style>
    .add-to-cart {
        display: inline-block;
        background-color: yellow;
        padding: 10px;
        border-radius: 50%;
        border: 2px solid #f1c40f;
        color: #f39c12;
        font-size: 20px;
        text-decoration: none;
    }

        .add-to-cart:hover {
            background-color: #f39c12;
            color: white;
        }

    .filters_menu li {
        cursor: pointer;
    }

        .filters_menu li.active {
            font-weight: bold;
        }

    .box {
        border: 1px solid #ddd;
        padding: 10px;
        margin-bottom: 20px;
    }
</style>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        // Filter functionality
        $('.filters_menu li').on('click', function () {
            var filterValue = $(this).attr('data-filter');

            // Remove active class from all menu items
            $('.filters_menu li').removeClass('active');
            // Add active class to the clicked item
            $(this).addClass('active');

            // Filter items
            if (filterValue === '*') {
                $('.grid .all').show();
            } else {
                $('.grid .all').hide();
                $(filterValue).show();
            }
        });

        // Add to cart functionality
        $('.add-to-cart').on('click', function (e) {
            e.preventDefault();

            // Get data from element attributes
            var dishId = $(this).data('id');
            var dishName = $(this).data('name');
            var dishPrice = $(this).data('price');
            var quantity = $(this).data('quantity');

            // Send data via AJAX
            $.ajax({
                url: "@Url.Action("Add", "Cart")",
                type: 'POST',
                contentType: 'application/x-www-form-urlencoded',
                data: {
                    DishId: dishId,
                    DishName: dishName,
                    DishPrice: dishPrice,
                    Quantity: quantity
                },
                success: function (response) {
                    alert('Dish added to cart successfully!');
                },
                error: function (xhr, status, error) {
                    alert('An error occurred: ' + error);
                }
            });
        });
    });
</script>
